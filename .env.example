# ─────────────────────────────────────────────────────────────
# Secrets — copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Claude (answer generation for AI search). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Voyage AI (embeddings for RAG). Get one at https://dash.voyageai.com
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Database (shared by all services)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_pw
POSTGRES_DB=retail
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────
# Models
# ─────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024

# ─────────────────────────────────────────────────────────────
# ETL schedule (cron). Default: every day at 02:00.
# ─────────────────────────────────────────────────────────────
ETL_CRON=0 2 * * *
